#################################
# See refs
# https://arxiv.org/abs/1111.2177v1
# https://arxiv.org/abs/1810.12346,
# https://arxiv.org/abs/0709.3559
# for Details
#################################
$rho                     = 1    # Refinement factor. Should be 1, 2, 4
$base_cells              = 50   # Initial number of cells to use
$dtfac                   = 0.5  # CFL
$crossing_times          = 1    # Run for this ammount of crossing times
$out_every_crossing_time = 1    # Output frequency
$diss_eps                = 0.02 # Dissipation strength
#################################

$num_cells  = $base_cells * $rho
$dx = 1.0 / $num_cells
$dt = $dtfac * $dx
$crossing_time_it = ceil(1.0 / $dt)
$itlast = $crossing_times * $crossing_time_it
$out_every = $out_every_crossing_time * $crossing_time_it

ActiveThorns = "
  ADMBaseX
  TmunuBaseX
  CarpetX
  CottonmouthBSSNOK4m
  IOUtil
  CottonmouthLinearWaveID
  ODESolvers
  TmunuBaseX
"

# Driver
Cactus::cctk_show_schedule       = yes
Cactus::presync_mode             = "presync-only"
CarpetX::verbose                 = yes
CarpetX::poison_undefined_values = yes

# Run Termination
Cactus::terminate   = "iteration"
Cactus::cctk_itlast = $itlast

# Grid setup
CarpetX::xmin = -0.5
CarpetX::ymin = -0.5
CarpetX::zmin = -0.5

CarpetX::xmax = 0.5
CarpetX::ymax = 0.5
CarpetX::zmax = 0.5

CarpetX::ncells_x = $num_cells
CarpetX::ncells_y = 8
CarpetX::ncells_z = 8

CarpetX::blocking_factor_x = 1
CarpetX::blocking_factor_y = 1
CarpetX::blocking_factor_z = 1

CarpetX::ghost_size = 3

CottonmouthBSSNOK4m::dissipation_epsilon = $diss_eps

# Boundary conditions
CarpetX::periodic   = yes
CarpetX::periodic_x = yes
CarpetX::periodic_y = yes
CarpetX::periodic_z = yes

# Initial data
ADMBaseX::initial_data    = "none"
ADMBaseX::initial_lapse   = "none"
ADMBaseX::initial_shift   = "none"
ADMBaseX::initial_dtlapse = "none"
ADMBaseX::initial_dtshift = "none"

# Time Integration
ODESolvers::verbose = yes
CarpetX::dtfac      = $dtfac
ODESolvers::method  = "RK4"

# Output
IO::out_dir   = $parfile
IO::out_every = $out_every

CarpetX::out_metadata           = no
CarpetX::out_performance        = no
CarpetX::output_boundary_points = no

CarpetX::out_tsv      = no
CarpetX::out_tsv_vars = "
  CottonmouthBSSNOK4m::gt
  CottonmouthBSSNOK4m::HamCons
  CottonmouthBSSNOK4m::MomCons
"
