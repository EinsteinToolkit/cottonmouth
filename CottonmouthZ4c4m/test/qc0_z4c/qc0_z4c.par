ActiveThorns = "
  ADMBaseX
  CarpetX
  CottonmouthZ4c4m
  CoordinatesX
  IOUtil
  NewRadX
  ODESolvers
  TmunuBaseX
  TwoPuncturesX
"

$itlast    = 32
$out_every = 2

# Driver
Cactus::cctk_show_schedule       = yes
Cactus::presync_mode             = "mixed-error"
CarpetX::verbose                 = yes
CarpetX::poison_undefined_values = no

# Run Termination
Cactus::terminate   = "iteration"
Cactus::cctk_itlast = $itlast

# Grid setup
CarpetX::xmin = -10.0
CarpetX::ymin = -10.0
CarpetX::zmin = -10.0

CarpetX::xmax = 10.0
CarpetX::ymax = 10.0
CarpetX::zmax = 10.0

CarpetX::ncells_x = 40
CarpetX::ncells_y = 40
CarpetX::ncells_z = 40

CarpetX::ghost_size          = 3
CarpetX::interpolation_order = 1

# Boundary conditions
CarpetX::boundary_x       = "neumann"
CarpetX::boundary_y       = "neumann"
CarpetX::boundary_z       = "neumann"
CarpetX::boundary_upper_x = "neumann"
CarpetX::boundary_upper_y = "neumann"
CarpetX::boundary_upper_z = "neumann"

# Mesh refinement
CarpetX::prolongation_type  = "ddf"
CarpetX::prolongation_order = 5

# Initial data
ADMBaseX::initial_data           = "TwoPunctures"
ADMBaseX::initial_lapse          = "TwoPunctures-averaged"

TwoPuncturesX::verbose           = yes
TwoPuncturesX::par_b             = 1.168642873
TwoPuncturesX::par_m_plus        = 0.453
TwoPuncturesX::par_m_minus       = 0.453
TwoPuncturesX::par_P_plus [1]    = +0.3331917498
TwoPuncturesX::par_P_minus[1]    = -0.3331917498
TwoPuncturesX::grid_setup_method = "evaluation"
TwoPuncturesX::TP_epsilon        = 1.0e-8
TwoPuncturesX::TP_Tiny           = 1.0e-8

# Time Integration
CarpetX::dtfac      = 0.25
ODESolvers::verbose = yes
ODESolvers::method  = "RK4"

# Spacetime evolution
CottonmouthZ4c4m::apply_NewRadX = yes

# Output
IO::out_dir   = $parfile
IO::out_every = $out_every

CarpetX::out_performance        = no
CarpetX::out_metadata           = no
CarpetX::output_boundary_points = no

CarpetX::out_tsv = no
CarpetX::out_tsv_vars = "
  ADMBaseX::metric
  ADMBaseX::curv
  CottonmouthZ4c4m::Theta
  CottonmouthZ4c4m::chi
  CottonmouthZ4c4m::trK
  CottonmouthZ4c4m::evo_Gammat
  CottonmouthZ4c4m::gt
  CottonmouthZ4c4m::At
  CottonmouthZ4c4m::evo_lapse
  CottonmouthZ4c4m::evo_shift
  CottonmouthZ4c4m::HamCons
  CottonmouthZ4c4m::MomCons
  CottonmouthZ4c4m::ZtCons
"
